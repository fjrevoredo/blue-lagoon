BLUE_LAGOON_CONFIG=config/default.toml
BLUE_LAGOON_DATABASE_URL=postgres://blue_lagoon:blue_lagoon@localhost:55432/blue_lagoon
BLUE_LAGOON_LOG=info

# Optional worker overrides. The harness otherwise expects a sibling `workers`
# binary next to the runtime binary.
BLUE_LAGOON_WORKER_COMMAND=
BLUE_LAGOON_WORKER_ARGS=[]
BLUE_LAGOON_WORKER_TIMEOUT_MS=10000

# Required for live Telegram foreground execution when using the default config.
BLUE_LAGOON_TELEGRAM_BOT_TOKEN=

# Direct foreground route and key overrides.
# Route format is '<provider>/<exact-model>'.
# Example: zai/glm-5-turbo
# Optional emergency API base URL override.
# Prefer provider-specific config such as [model_gateway.z_ai] api_surface = "coding".
BLUE_LAGOON_FOREGROUND_ROUTE=
BLUE_LAGOON_FOREGROUND_API_BASE_URL=
BLUE_LAGOON_FOREGROUND_API_KEY=
